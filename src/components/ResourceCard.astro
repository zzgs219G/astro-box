---
export interface Props {
  id: string;
  title: string;
  description: string;
  lanzaoUrl: string;
  iconUrl?: string;
  categoryId: string;
  tagId: string;
}

const { id, title, description, lanzaoUrl, iconUrl, categoryId, tagId } = Astro.props;

// Determine emoji based on file title
let emoji = '📄';
const lowerTitle = title.toLowerCase();
if (lowerTitle.endsWith('.apk')) emoji = '📱';
else if (lowerTitle.endsWith('.zip') || lowerTitle.endsWith('.rar') || lowerTitle.endsWith('.7z')) emoji = '📦';
else if (lowerTitle.endsWith('.mp4') || lowerTitle.endsWith('.avi') || lowerTitle.endsWith('.mkv')) emoji = '🎬';
else if (lowerTitle.endsWith('.mp3') || lowerTitle.endsWith('.flac')) emoji = '🎵';
else if (lowerTitle.endsWith('.jpg') || lowerTitle.endsWith('.png') || lowerTitle.endsWith('.gif')) emoji = '🖼️';
else if (lowerTitle.endsWith('.pdf') || lowerTitle.endsWith('.doc') || lowerTitle.endsWith('.docx') || lowerTitle.endsWith('.txt')) emoji = '📚';
else if (!title.includes('.')) emoji = '📁'; // Rough heuristic for folders

// Parse description string to get cleaner info
// Example input: "大小: 23.7 M  |  更新时间: 2025-09-09"
let size = '';
let time = '';
const parts = description.split('|');
if (parts.length === 2) {
  size = parts[0].replace('大小:', '').trim();
  time = parts[1].replace('更新时间:', '').trim();
} else {
  size = description;
}
---

<div
  class="resource-card group flex flex-col bg-white dark:bg-[#18181b] rounded-2xl p-5 border border-gray-200/60 dark:border-[#27272a] shadow-sm hover:shadow-md transition-all duration-300"
  data-category={categoryId}
  data-tag={tagId}
  data-title={title.toLowerCase()}
>
  <div class="flex items-start space-x-4 mb-4">
    <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-xl bg-gray-50 dark:bg-[#27272a] border border-gray-100 dark:border-[#3f3f46] text-2xl overflow-hidden group-hover:scale-105 transition-transform duration-300">
      {iconUrl ? (
        <img src={iconUrl} alt="icon" class="w-full h-full object-cover"
             onerror={`this.onerror=null; this.outerHTML='<span class="opacity-80">${emoji}</span>';`} />
      ) : (
        <span class="opacity-80">{emoji}</span>
      )}
    </div>
    <div class="flex-1 min-w-0 pt-0.5">
      <h3 class="text-base font-bold text-gray-900 dark:text-gray-100 truncate group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors" title={title}>
        {title}
      </h3>
      <div class="mt-1 flex flex-wrap gap-x-3 gap-y-1 text-xs text-gray-500 dark:text-gray-400">
        {size && (
          <span>{size}</span>
        )}
        {size && time && <span class="text-gray-300 dark:text-gray-600">•</span>}
        {time && (
          <span>{time}</span>
        )}
      </div>
    </div>
  </div>

  <div class="mt-auto pt-3">
    <a
      href={lanzaoUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-center w-full py-2 px-4 rounded-xl text-sm font-medium text-gray-700 dark:text-gray-200 bg-gray-50 dark:bg-[#27272a] hover:bg-indigo-50 hover:text-indigo-600 dark:hover:bg-indigo-500/10 dark:hover:text-indigo-400 transition-colors active:scale-95"
    >
      直达资源
      <svg class="w-3.5 h-3.5 ml-1.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
    </a>
  </div>
</div>
