---
export interface Props {
  id: string;
  title: string;
  description: string;
  lanzaoUrl: string;
  categoryId: string;
  tagId: string;
}

const { id, title, description, lanzaoUrl, categoryId, tagId } = Astro.props;

// Determine emoji based on file title
let emoji = '📄';
const lowerTitle = title.toLowerCase();
if (lowerTitle.endsWith('.apk')) emoji = '📱';
else if (lowerTitle.endsWith('.zip') || lowerTitle.endsWith('.rar') || lowerTitle.endsWith('.7z')) emoji = '📦';
else if (lowerTitle.endsWith('.mp4') || lowerTitle.endsWith('.avi') || lowerTitle.endsWith('.mkv')) emoji = '🎬';
else if (lowerTitle.endsWith('.mp3') || lowerTitle.endsWith('.flac')) emoji = '🎵';
else if (lowerTitle.endsWith('.jpg') || lowerTitle.endsWith('.png') || lowerTitle.endsWith('.gif')) emoji = '🖼️';
else if (lowerTitle.endsWith('.pdf') || lowerTitle.endsWith('.doc') || lowerTitle.endsWith('.docx') || lowerTitle.endsWith('.txt')) emoji = '📚';
else if (!title.includes('.')) emoji = '📁'; // Rough heuristic for folders

// Parse description string to get cleaner info
// Example input: "大小: 23.7 M  |  更新时间: 2025-09-09"
let size = '';
let time = '';
const parts = description.split('|');
if (parts.length === 2) {
  size = parts[0].replace('大小:', '').trim();
  time = parts[1].replace('更新时间:', '').trim();
} else {
  size = description;
}
---

<div
  class="resource-card group flex flex-col bg-white/60 dark:bg-gray-800/60 backdrop-blur-md rounded-2xl p-5 shadow-sm border border-gray-200/50 dark:border-gray-700/50 transition-all duration-300 hover:shadow-lg hover:scale-[1.02] hover:ring-2 hover:ring-blue-400/50 dark:hover:ring-blue-500/50"
  data-category={categoryId}
  data-tag={tagId}
  data-title={title.toLowerCase()}
>
  <div class="flex items-start space-x-4 mb-4">
    <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-xl bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-gray-700 dark:to-gray-800 shadow-inner text-2xl">
      {emoji}
    </div>
    <div class="flex-1 min-w-0">
      <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 truncate group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors" title={title}>
        {title}
      </h3>
      <div class="mt-1 flex flex-wrap gap-2 text-xs text-gray-500 dark:text-gray-400">
        {size && (
          <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-700">
            <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
            {size}
          </span>
        )}
        {time && (
          <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-700">
            <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            {time}
          </span>
        )}
      </div>
    </div>
  </div>

  <div class="mt-auto pt-2">
    <a
      href={lanzaoUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-center w-full py-2 px-4 rounded-xl text-sm font-medium text-white bg-blue-500/90 hover:bg-blue-600/90 dark:bg-blue-600/90 dark:hover:bg-blue-500/90 backdrop-blur-sm transition-all duration-200 active:scale-95 shadow-sm"
    >
      直达资源
      <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
    </a>
  </div>
</div>
