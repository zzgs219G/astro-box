---
import Layout from '../../layouts/Layout.astro';
---
<Layout>
<div class="max-w-4xl mx-auto py-12 px-4">
<div class="text-center mb-10">
<h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">💧 图片加水印</h1>
<p class="text-gray-500 dark:text-gray-400">本地添加文字水印，自定义位置、颜色、透明度</p>
</div>
<div class="bg-white/60 dark:bg-zinc-900/60 backdrop-blur-sm rounded-[1.25rem] p-8 border border-gray-200/50 dark:border-zinc-800/50 shadow-sm">
<div
id="dropzone"
class="border-2 border-dashed border-gray-300 dark:border-zinc-700 rounded-xl p-12 text-center cursor-pointer hover:border-primary-500 hover:bg-primary-50 dark:hover:bg-primary-500/10 transition-colors duration-300"
>
<div class="text-4xl mb-4">📤</div>
<p class="text-gray-600 dark:text-gray-300 font-medium">点击或拖拽上传图片</p>
</div>
<input type="file" id="fileInput" accept="image/*" class="hidden" />
<div id="workspace" class="hidden mt-8 grid grid-cols-1 md:grid-cols-2 gap-8">
<div class="space-y-6">
<div>
<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">水印文字</label>
<input
type="text"
id="watermarkText"
value="仅供参考"
class="w-full px-4 py-2 bg-gray-50 dark:bg-zinc-800 border border-gray-200 dark:border-zinc-700 rounded-xl text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 outline-none"
/>
</div>
<div>
<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">颜色</label>
<input type="color" id="watermarkColor" value="#ffffff" class="w-12 h-12 p-1 bg-transparent border-0 cursor-pointer rounded-xl" />
</div>
<div>
<div class="flex items-center justify-between mb-2">
<label class="text-sm font-medium text-gray-700 dark:text-gray-300">透明度</label>
<span id="opacityValue" class="text-sm text-gray-500 dark:text-gray-400">50%</span>
</div>
<input type="range" id="watermarkOpacity" min="0" max="1" step="0.05" value="0.5" class="w-full accent-primary-600" />
</div>
<div>
<div class="flex items-center justify-between mb-2">
<label class="text-sm font-medium text-gray-700 dark:text-gray-300">字体大小 (比例)</label>
<span id="sizeValue" class="text-sm text-gray-500 dark:text-gray-400">5%</span>
</div>
<input type="range" id="watermarkSize" min="0.01" max="0.3" step="0.01" value="0.05" class="w-full accent-primary-600" />
</div>
<div>
<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">位置</label>
<div class="grid grid-cols-3 gap-2 w-32">
<button class="pos-btn border border-gray-200 dark:border-zinc-700 p-2 rounded hover:bg-gray-100 dark:hover:bg-zinc-800" data-pos="top-left">↖</button>
<button class="pos-btn border border-gray-200 dark:border-zinc-700 p-2 rounded hover:bg-gray-100 dark:hover:bg-zinc-800" data-pos="top-center">↑</button>
<button class="pos-btn border border-gray-200 dark:border-zinc-700 p-2 rounded hover:bg-gray-100 dark:hover:bg-zinc-800" data-pos="top-right">↗</button>
<button class="pos-btn border border-gray-200 dark:border-zinc-700 p-2 rounded hover:bg-gray-100 dark:hover:bg-zinc-800" data-pos="center-left">←</button>
<button class="pos-btn border border-gray-200 dark:border-zinc-700 p-2 rounded hover:bg-gray-100 dark:hover:bg-zinc-800 bg-primary-50 dark:bg-primary-500/10 border-primary-500" data-pos="center">·</button>
<button class="pos-btn border border-gray-200 dark:border-zinc-700 p-2 rounded hover:bg-gray-100 dark:hover:bg-zinc-800" data-pos="center-right">→</button>
<button class="pos-btn border border-gray-200 dark:border-zinc-700 p-2 rounded hover:bg-gray-100 dark:hover:bg-zinc-800" data-pos="bottom-left">↙</button>
<button class="pos-btn border border-gray-200 dark:border-zinc-700 p-2 rounded hover:bg-gray-100 dark:hover:bg-zinc-800" data-pos="bottom-center">↓</button>
<button class="pos-btn border border-gray-200 dark:border-zinc-700 p-2 rounded hover:bg-gray-100 dark:hover:bg-zinc-800" data-pos="bottom-right">↘</button>
</div>
</div>
<div class="pt-4">
<button id="downloadBtn" class="w-full py-3 bg-primary-600 hover:bg-primary-700 text-white rounded-xl font-medium transition-colors duration-300 shadow-sm">
下载图片
</button>
</div>
</div>
<div class="flex flex-col">
<h3 class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">实时预览</h3>
<div class="flex-1 bg-gray-100 dark:bg-zinc-800 rounded-xl p-2 flex items-center justify-center overflow-hidden min-h-[300px]">
<img id="previewImage" class="max-w-full max-h-full object-contain shadow-sm" />
</div>
</div>
</div>
</div>
</div>
</Layout>
<script>
let originalFile: File | null = null;
let originalImage = new Image();
let resultUrl: string | null = null;
let dropzone: HTMLElement | null = null;
let fileInput: HTMLInputElement | null = null;
let workspace: HTMLElement | null = null;
let previewImage: HTMLImageElement | null = null;
let textInput: HTMLInputElement | null = null;
let colorInput: HTMLInputElement | null = null;
let opacityInput: HTMLInputElement | null = null;
let sizeInput: HTMLInputElement | null = null;
let opacityValue: HTMLElement | null = null;
let sizeValue: HTMLElement | null = null;
let posBtns: NodeListOf<Element> | null = null;
let downloadBtn: HTMLElement | null = null;
let currentPosition = 'center';

function handleFile(file: File) {
if (!dropzone || !workspace) return;
if (!file.type.startsWith('image/')) {
alert('请上传图片文件');
return;
}
originalFile = file;
dropzone.classList.add('hidden');
workspace.classList.remove('hidden');
const url = URL.createObjectURL(file);
originalImage.onload = () => {
drawWatermark();
URL.revokeObjectURL(url);
};
originalImage.src = url;
}

function drawWatermark() {
if (!originalFile || !originalImage.src || !textInput || !colorInput || !opacityInput || !sizeInput) return;
const canvas = document.createElement('canvas');
canvas.width = originalImage.width;
canvas.height = originalImage.height;
const ctx = canvas.getContext('2d');
if (!ctx) return;
ctx.drawImage(originalImage, 0, 0);
const text = textInput.value;
if (!text) {
updatePreview(canvas);
return;
}
const fontSize = originalImage.width * parseFloat(sizeInput.value);
ctx.font = `bold ${fontSize}px sans-serif`;
const hex = colorInput.value;
const r = parseInt(hex.slice(1, 3), 16);
const g = parseInt(hex.slice(3, 5), 16);
const b = parseInt(hex.slice(5, 7), 16);
const a = parseFloat(opacityInput.value);
ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${a})`;
ctx.textBaseline = 'middle';
ctx.textAlign = 'center';
const metrics = ctx.measureText(text);
const textWidth = metrics.width;
const padding = fontSize * 0.5;
let x = 0;
let y = 0;
switch (currentPosition) {
case 'top-left': x = textWidth / 2 + padding; y = fontSize / 2 + padding; break;
case 'top-center': x = canvas.width / 2; y = fontSize / 2 + padding; break;
case 'top-right': x = canvas.width - textWidth / 2 - padding; y = fontSize / 2 + padding; break;
case 'center-left': x = textWidth / 2 + padding; y = canvas.height / 2; break;
case 'center': x = canvas.width / 2; y = canvas.height / 2; break;
case 'center-right': x = canvas.width - textWidth / 2 - padding; y = canvas.height / 2; break;
case 'bottom-left': x = textWidth / 2 + padding; y = canvas.height - fontSize / 2 - padding; break;
case 'bottom-center': x = canvas.width / 2; y = canvas.height - fontSize / 2 - padding; break;
case 'bottom-right': x = canvas.width - textWidth / 2 - padding; y = canvas.height - fontSize / 2 - padding; break;
}
ctx.fillText(text, x, y);
updatePreview(canvas);
}

function updatePreview(canvas: HTMLCanvasElement) {
if (!previewImage) return;
canvas.toBlob((blob) => {
if (!blob) return;
if (resultUrl) URL.revokeObjectURL(resultUrl);
resultUrl = URL.createObjectURL(blob);
previewImage!.src = resultUrl;
}, originalFile?.type || 'image/png', 0.95);
}

function init() {
dropzone = document.getElementById('dropzone');
fileInput = document.getElementById('fileInput') as HTMLInputElement | null;
workspace = document.getElementById('workspace');
previewImage = document.getElementById('previewImage') as HTMLImageElement | null;
textInput = document.getElementById('watermarkText') as HTMLInputElement | null;
colorInput = document.getElementById('watermarkColor') as HTMLInputElement | null;
opacityInput = document.getElementById('watermarkOpacity') as HTMLInputElement | null;
sizeInput = document.getElementById('watermarkSize') as HTMLInputElement | null;
opacityValue = document.getElementById('opacityValue');
sizeValue = document.getElementById('sizeValue');
posBtns = document.querySelectorAll('.pos-btn');
downloadBtn = document.getElementById('downloadBtn');

if (!dropzone || !fileInput || !workspace || !textInput || !colorInput || !opacityInput || !sizeInput || !opacityValue || !sizeValue || !downloadBtn) return;

if (posBtns) {
posBtns.forEach(btn => {
btn.addEventListener('click', (e) => {
const target = e.target as HTMLButtonElement;
currentPosition = target.dataset.pos || 'center';
if (posBtns) {
posBtns.forEach(b => {
b.classList.remove('bg-primary-50', 'dark:bg-primary-500/10', 'border-primary-500');
});
}
target.classList.add('bg-primary-50', 'dark:bg-primary-500/10', 'border-primary-500');
drawWatermark();
});
});
}
textInput.addEventListener('input', drawWatermark);
colorInput.addEventListener('input', drawWatermark);
opacityInput.addEventListener('input', () => {
if (!opacityInput || !opacityValue) return;
opacityValue.textContent = `${Math.round(parseFloat(opacityInput.value) * 100)}%`;
drawWatermark();
});
sizeInput.addEventListener('input', () => {
if (!sizeInput || !sizeValue) return;
sizeValue.textContent = `${Math.round(parseFloat(sizeInput.value) * 100)}%`;
drawWatermark();
});
dropzone.addEventListener('click', () => fileInput?.click());
dropzone.addEventListener('dragover', (e) => {
e.preventDefault();
dropzone?.classList.add('border-primary-500', 'bg-primary-50', 'dark:bg-primary-500/10');
});
dropzone.addEventListener('dragleave', (e) => {
e.preventDefault();
dropzone?.classList.remove('border-primary-500', 'bg-primary-50', 'dark:bg-primary-500/10');
});
dropzone.addEventListener('drop', (e) => {
e.preventDefault();
dropzone?.classList.remove('border-primary-500', 'bg-primary-50', 'dark:bg-primary-500/10');
const file = e.dataTransfer?.files[0];
if (file) handleFile(file);
});
fileInput.addEventListener('change', (e) => {
const file = fileInput?.files?.[0];
if (file) handleFile(file);
});
downloadBtn.addEventListener('click', () => {
if (!resultUrl || !originalFile) return;
const baseName = originalFile.name.replace(/\.[^/.]+$/, "");
const ext = originalFile.name.split('.').pop();
const a = document.createElement('a');
a.href = resultUrl;
a.download = `${baseName}_watermark.${ext}`;
a.click();
});
}

// 👂 接收 Layout 传来的全局重载命令
document.addEventListener('page-changed', () => {
if (document.getElementById('dropzone')) {
init();
}
});
</script>
