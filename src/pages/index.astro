---
import Layout from '../layouts/Layout.astro';
import ResourceExplorer from '../components/ResourceExplorer.svelte';
import fs from 'fs';
import path from 'path';
import type { Database, ResourceItem } from '../types';

// Hardcoded Categories Priority
const categories = [
  { id: "toolbox", name: "🧰 工具箱" },
  { id: "all", name: "全部资源" },
  { id: "software", name: "软件库" }
];

// Read databases during build time
const lanzouPath = path.join(process.cwd(), 'public', 'lanzou_db.json');
const toolsPath = path.join(process.cwd(), 'public', 'tools_db.json');

let dbData: Database = { categories: [], tags: [], list: [] };
let toolsList: ResourceItem[] = [];

try {
  if (fs.existsSync(lanzouPath)) {
    const rawData = fs.readFileSync(lanzouPath, 'utf-8');
    dbData = JSON.parse(rawData);
  } else {
    console.warn("lanzou_db.json not found during build. Please run fetch-lanzou.js first.");
  }
} catch (e) {
  console.error("Error reading lanzou_db.json", e);
}

try {
  if (fs.existsSync(toolsPath)) {
    const rawData = fs.readFileSync(toolsPath, 'utf-8');
    const toolsDb = JSON.parse(rawData);
    if (toolsDb && toolsDb.list) {
      toolsList = toolsDb.list;
    }
  }
} catch (e) {
  console.error("Error reading tools_db.json", e);
}

const { tags, list: lanzouList } = dbData;
const mergedList = [...toolsList, ...lanzouList];
---

<Layout>
  <ResourceExplorer
    client:load
    categories={categories}
    tags={tags}
    list={mergedList}
  />
</Layout>
